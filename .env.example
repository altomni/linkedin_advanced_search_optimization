OPENAI_API_KEY=

# API Configuration
API_PORT=5100

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=False

# SYNONYM API
SYNONYM_ASSOCIATION_API_BASE_URL=http://172.32.10.240:33001 #http://10.0.0.213:33001

# Search Channel
SEARCH_CHANNEL=recruiter

# Language filtering - Maximum concurrent LLM calls for language evaluation
# Controls how many candidates can be evaluated in parallel during language filtering
# Higher value = faster processing but higher API cost
# Recommended: 5-10 for cost control, 10-20 for speed
MAX_CONCURRENT_LANGUAGE_LLM_CALLS=30

# Phase-4 dynamic-scorer concurrency (max simultaneous candidate-scoring LLM calls)
EVAL_MAX_CONCURRENCY=30

# Minimum acceptable language recommendation level for candidates
# Valid values: PASS, LIKELY_PASS, PARTIAL, FAIL (default: FAIL)
#
# Recommendation levels (from best to worst):
# - PASS         (score >= 90)  - Strong evidence of language capability
# - LIKELY_PASS  (score >= 70)  - Good evidence of language capability
# - PARTIAL      (score >= 40)  - Some evidence but uncertain
# - FAIL         (score < 40)   - No/weak evidence of language capability
#
# Filter behavior:
# - FAIL         → Only filter candidates with FAIL recommendation (most lenient)
# - PARTIAL      → Filter candidates with PARTIAL or FAIL (medium strictness)
# - LIKELY_PASS  → Filter candidates with LIKELY_PASS, PARTIAL, or FAIL (strict)
# - PASS         → Only accept candidates with PASS (most strict)
#
# Examples:
#   LANGUAGE_FILTER_MIN_LEVEL=FAIL        # Default: Only exclude clear mismatches
#   LANGUAGE_FILTER_MIN_LEVEL=PARTIAL     # Exclude uncertain matches
#   LANGUAGE_FILTER_MIN_LEVEL=LIKELY_PASS # Only accept strong matches
#
LANGUAGE_FILTER_MIN_LEVEL=FAIL

# Two-round search configuration (for optimizing candidate pool size)
# Minimum candidates from first search (with language) to skip second round (default: 10)
# If first search returns fewer candidates, a second search without language filter will be triggered
LANGUAGE_SEARCH_MIN_THRESHOLD=100

# Maximum candidates to retrieve in second search (without language filter) (default: 500)
# Second round uses LLM evaluation to filter candidates by language capability
LANGUAGE_SECOND_SEARCH_MAX=800


# Reparse value mode for get_reparse_value()
# Options: "key_value" (returns "key: value"), "form_value" (returns form_value), "skip" (returns None)
REPARSE_VALUE_MODE=key_value
# Reparse target statuses - which statuses to process in parse_reparse_value()
# Comma-separated list, default: dismissed,customized
REPARSE_TARGET_STATUSES=dismissed,customized,modified

# =============================================================================
# Redis (async optimize-fetch task queue/status/result store)
# Same env vars as JDSearchAgent's reranking/optfetch services so all share one Redis.
# Under docker compose, REDIS_HOST defaults to the bundled `redis` service; set it here
# only to point at an external Redis (must match between the API and the worker).
# =============================================================================

#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=

# Task queue name + result/task-record TTLs (defaults: 24h results, 7d queued tasks)
#OPTFETCH_QUEUE=optfetch:queue
#OPTFETCH_RESULT_TTL_SECONDS=86400
#OPTFETCH_QUEUED_TTL_SECONDS=604800

# Crash recovery: a "running" task whose worker heartbeat is older than STALE_SECONDS
# is requeued up to MAX_RETRIES times, then marked failed
#OPTFETCH_HEARTBEAT_SECONDS=15
#OPTFETCH_STALE_SECONDS=120
#OPTFETCH_MAX_RETRIES=1

# Where streamed per-archetype candidates go when push_to_rerank=true
#RERANK_INPUT_QUEUE=reranking:input

# =============================================================================
# LLM Observability & Tracing Configuration (Comment out bellow if you don't need it)
# =============================================================================

# Langfuse Configuration (Open-source LLM Observability)
# Docs: https://langfuse.com/docs
# Note: One key pair per Langfuse project, use trace names to distinguish graphs
LANGFUSE_ENABLED=False
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://192.168.1.27:3012